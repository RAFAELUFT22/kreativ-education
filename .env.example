# =============================================================================
# kreativ-education / TDS — Environment Variables Template
# Copie para .env e preencha com seus valores reais.
# JAMAIS commite o arquivo .env com senhas reais.
# =============================================================================

# --- Domínio e TLS ---
DOMAIN=ipexdesenvolvimento.cloud
LETSENCRYPT_EMAIL=admin@ipexdesenvolvimento.cloud

# --- MariaDB (Frappe) ---
MARIADB_ROOT_PASSWORD=troque_por_senha_forte_aqui
MARIADB_FRAPPE_PASSWORD=troque_por_senha_frappe_aqui

# --- Frappe Site ---
FRAPPE_SITE_NAME=lms.ipexdesenvolvimento.cloud
FRAPPE_ADMIN_PASSWORD=troque_por_senha_admin_aqui

# --- Frappe API (geradas após setup via UI: Usuário > API Access > Gerar Chaves) ---
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# --- PostgreSQL (N8N, Evolution API, Chatwoot) ---
PG_USER=kreativ
PG_PASSWORD=troque_por_senha_pg_aqui
PG_DATABASE=kreativ_edu

# --- Redis (compartilhado — separado por DB index internamente) ---
REDIS_PASSWORD=troque_por_senha_redis_aqui

# --- Pilar 1: Gateway WhatsApp — Evolution API ---
EVOLUTION_API_KEY=troque_api_key_evolution
EVOLUTION_DB=evolution_db
EVOLUTION_GLOBAL_WEBHOOK=https://n8n.ipexdesenvolvimento.cloud/webhook/whatsapp-kreativ

# --- Pilar 2: Orquestrador — N8N ---
N8N_ENCRYPTION_KEY=troque_encryption_n8n_aqui
N8N_URL=https://n8n.ipexdesenvolvimento.cloud

# --- Pilar 3: Tutor Cognitivo — AnythingLLM ---
ANYTHINGLLM_API_KEY=
LLM_PROVIDER=google
LLM_MODEL_PREF=gemini-1.5-flash

# LLM Cloud Providers (preencha o que for usar)
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Pilar 4: Fonte da Verdade — Frappe LMS (ver acima) ---
# FRAPPE_SITE_NAME, FRAPPE_ADMIN_PASSWORD, FRAPPE_API_KEY, FRAPPE_API_SECRET

# --- Pilar 5: Inbox Humana — Chatwoot ---
CHATWOOT_SECRET_KEY=troque_secret_chatwoot_aqui
CHATWOOT_URL=https://chat.ipexdesenvolvimento.cloud
CHATWOOT_API_KEY=
CHATWOOT_ADMIN_EMAIL=admin@ipexdesenvolvimento.cloud
CHATWOOT_ADMIN_PASSWORD=troque_por_senha_chatwoot_aqui

# (Opcional) OpenAI para AI Assist do Chatwoot
OPENAI_API_KEY=

# --- Typebot (opcional — adicionar ao stack separado) ---
TYPEBOT_NEXTAUTH_SECRET=troque_secret_typebot_aqui
TYPEBOT_ENCRYPTION_SECRET=troque_encryption_typebot_aqui
TYPEBOT_ADMIN_EMAIL=admin@ipexdesenvolvimento.cloud

# --- MinIO Storage (opcional — adicionar ao stack separado) ---
MINIO_ROOT_USER=kreativ_minio
MINIO_ROOT_PASSWORD=troque_por_senha_minio_aqui
